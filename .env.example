# ============================================
# 🔧 Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# --- Authentication ---
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="7d"
SESSION_SECRET="another-long-random-string-for-oauth-sessions"

# --- OAuth: Google (https://console.cloud.google.com/apis/credentials) ---
# Authorized redirect URI: http://localhost:4000/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- OAuth: GitHub (https://github.com/settings/developers) ---
# Authorization callback URL: http://localhost:4000/api/auth/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- OAuth: Apple (https://developer.apple.com/account/resources/identifiers) ---
# Return URL: http://localhost:4000/api/auth/apple/callback  (requires paid Apple Developer account)
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# --- Backend Server ---
PORT=4000
NODE_ENV=development

# --- Frontend ---
FRONTEND_URL="http://localhost:3000"

# --- Razorpay ---
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
RAZORPAY_PLAN_ID=""          # Optional: pre-created plan ID; auto-created if blank

# --- AI (Gemini) ---
GEMINI_API_KEY=""             # Google AI Studio: https://aistudio.google.com/app/apikey

# --- AWS S3 (Phase 3) ---
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION=""
CLOUDFRONT_DOMAIN=""
